{
  "name": "joshmu-dance-website",
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "keywords": [
    "art",
    "dance",
    "josh mu",
    "website",
    "yoga"
  ],
  "homepage": "https://github.com/joshmu/joshmu-dance-website",
  "bugs": {
    "url": "https://github.com/joshmu/joshmu-dance-website/issues"
  },
  "license": "MIT",
  "author": "Josh Mu",
  "repository": {
    "type": "git",
    "url": "https://github.com/joshmu/joshmu-dance-website.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint src/",
    "lint:fix": "oxlint --fix src/",
    "format": "oxfmt src/",
    "format:check": "oxfmt --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint:md": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:knip": "pnpm exec knip",
    "audit": "pnpm audit --audit-level=high",
    "validate": "pnpm typecheck && pnpm lint && pnpm format:check",
    "prepare": "husky"
  },
  "dependencies": {
    "framer-motion": "^12.23.6",
    "next": "16.2.1",
    "nodemailer": "^6.9.3",
    "react": "^19.2.4",
    "react-device-detect": "^2.2.3",
    "react-dom": "^19.2.4",
    "react-ga": "^3.3.1",
    "react-icons": "^4.10.1",
    "react-intersection-observer": "^8.34.0",
    "react-scroll": "^1.8.9"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "22.16.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.14",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "knip": "^6.1.0",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "postcss": "^8.4.24",
    "postcss-preset-env": "^7.8.3",
    "sass": "^1.63.6",
    "tailwindcss": "^3.3.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "oxfmt --write",
      "oxlint --fix"
    ],
    "*.{json,css}": [
      "oxfmt --write"
    ],
    "*.md": [
      "markdownlint-cli2"
    ]
  }
}
